# ─────────────────────────────────────────────────────────────
# Sanity CMS — required for the /studio dashboard and live data
# Create a free project at https://sanity.io/manage, then copy
# this file to `.env.local` and fill in the values below.
# ─────────────────────────────────────────────────────────────

# Found in https://sanity.io/manage -> your project -> Project ID
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Usually "production"
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API version — pin to a date; do not use "latest" in production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Editor/write token. ONLY needed to run `npm run seed`.
# Create at https://sanity.io/manage -> API -> Tokens -> "Editor" permission.
# Never expose this to the browser and never commit it.
SANITY_API_WRITE_TOKEN=

# ─────────────────────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────────────────────

# Canonical origin, used for metadata, sitemap.xml, robots.txt and JSON-LD.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Contact channels (surfaced in the header, footer, floating
# WhatsApp button and the property agent card)
# ─────────────────────────────────────────────────────────────

# International format, digits only — no "+", spaces or dashes.
NEXT_PUBLIC_WHATSAPP_NUMBER=201000000000
NEXT_PUBLIC_CONTACT_PHONE=+20 100 000 0000
NEXT_PUBLIC_CONTACT_EMAIL=invest@rise-estates.com
